# === OAuth ===
# Discord: https://discord.com/developers → New Application → OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# === Session ===
# Any random string — used to sign session cookies
SESSION_SECRET=change-this-to-a-random-string

# === App ===
# Your deployed URL (or http://localhost:3000 for dev)
APP_URL=http://localhost:3000

# === Backend Sync ===
# Shared secret between frontend server and backend API for server-to-server auth
API_SHARED_SECRET=
# Backend API URL
API_URL=https://16-112-132-239.sslip.io
